# Raspberry Pi offsite backup node setup configuration

# Mount/config paths
NAS_MOUNT_POINT="/srv/nas"
BACKUP_DIR="/srv/nas/backup"
HOME_NAS_SYMLINK="$HOME/nas"

# Drive configuration
# Leave blank to have the storage step print detected filesystems and prompt for the UUID.
NAS_DEVICE_UUID=""
NAS_FILESYSTEM_TYPE="ext4"
NAS_MOUNT_OPTIONS="defaults,nofail,noatime"

# Optional features
ENABLE_TAILSCALE="true"
# ENABLE_SAMBA="false"
ENABLE_NUT="false"
ENABLE_SPINDOWN="false"
ENABLE_BASH_ALIASES="true"

# Tailscale
TAILSCALE_HOSTNAME="rpi"

# Samba
# SAMBA_SHARE_NAME="nas"
# SAMBA_SHARE_COMMENT="Raspberry Pi NAS"
# SAMBA_ALLOWED_USER="$USER"

# Logging
LOG_DIR="./logs"
